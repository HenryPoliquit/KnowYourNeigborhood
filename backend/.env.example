# Postgres connection.
# Local dev: a local Postgres (set DB_SSL=false for plaintext localhost).
# Production (Supabase serverless): use the TRANSACTION POOLER URL on port 6543
#   with ?sslmode=require, e.g.
#   postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# For one-off `npm run db:init`, use the DIRECT/session connection (port 5432).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kyn

# Set to false ONLY for a local plaintext Postgres. Leave unset/true for Supabase.
DB_SSL=false

# JWT signing secret — use a long random string (generate a fresh one for prod).
JWT_SECRET=change-me-to-a-long-random-secret

# Server port. Local only — do NOT set on Vercel.
PORT=3000

# Allowed CORS origin. Local: http://localhost:5173
# Production: the deployed frontend URL, e.g. https://<frontend-project>.vercel.app
CORS_ORIGIN=http://localhost:5173

# Google OAuth (Web application client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
