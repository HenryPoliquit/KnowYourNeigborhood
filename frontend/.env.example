# Base URL of the Fastify API.
# Local dev: http://localhost:3000
# Production: set this in the Vercel project's Environment Variables to the
# deployed backend URL, e.g. https://<backend-project>.vercel.app
VITE_API_URL=http://localhost:3000

# Google OAuth Web client ID (same value as backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
